{
  "expo": {
    "name": "Girly Vibes",
    "slug": "girlyvibes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "girlyvibes",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBE4EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.girlyvibes.app"
    },
    "android": {
      "package": "com.girlyvibes.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FBE4EC"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Girly Vibes to save photos to your gallery.",
          "savePhotosPermission": "Allow Girly Vibes to save photos to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0a4a34ef-be6e-481f-9e5d-540aa134bc79"
      }
    },
    "owner": "neurocoode"
  }
}
