{
  "expo": {
    "name": "Girly Vibes",
    "slug": "girlyvibes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "girlyvibes",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "locales": {
      "ar": "./locales/ar.json"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBE4EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.girlyvibes.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FBE4EC"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "assets": [
      "./assets/fonts/MaterialCommunityIcons.ttf",
      "./assets/fonts/Feather.ttf",
      "./assets/fonts/Ionicons.ttf"
    ],
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/MaterialCommunityIcons.ttf",
            "./assets/fonts/Feather.ttf",
            "./assets/fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
